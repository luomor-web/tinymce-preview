{
  "name": "tinymce-plugin-multipreview",
  "version": "1.0.0",
  "description": "TinyMCE 多端预览插件，支持手机、平板、PC 三种视口预览",
  "main": "dist/plugin.cjs.js",
  "module": "dist/plugin.esm.js",
  "unpkg": "dist/plugin.umd.js",
  "types": "dist/plugin.d.ts",
  "files": [
    "dist",
    "src",
    "vue"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:vue": "vue-tsc --noEmit && vite build --config vite.vue.config.js",
    "preview": "vite preview",
    "release": "npm run build && npm run build:vue && npm publish"
  },
  "keywords": [
    "tinymce",
    "tinymce-plugin",
    "preview",
    "multi-device",
    "responsive",
    "vue"
  ],
  "author": "zhangchunsheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luomor-web/tinymce-preview"
  },
  "peerDependencies": {
    "tinymce": "^5.0.0 || ^6.0.0"
  },
  "optionalDependencies": {
    "@tinymce/tinymce-vue": "^3 || ^4 || ^5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "tinymce": "^6.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^1.8.0"
  }
}
